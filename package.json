{
  "name": "typescript-algorithms-data-structures",
  "version": "1.0.0",
  "description": "TypeScript implementations of classic algorithms and data structures with tests, CI/CD, Docker support, and a static GitHub Pages playground.",
  "private": true,
  "scripts": {
    "test": "jest --verbose",
    "test:watch": "jest --watch",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "build": "npm run typecheck"
  },
  "keywords": ["typescript", "algorithms", "data-structures", "jest", "testing", "github-actions", "ci-cd", "github-pages", "docker"],
  "author": "Nikita Krivoshei",
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "@typescript-eslint/eslint-plugin": "^6.19.1",
    "@typescript-eslint/parser": "^6.19.1",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-jest": "^27.6.3",
    "eslint-plugin-prettier": "^5.1.3",
    "jest": "^29.7.0",
    "prettier": "^3.2.4",
    "ts-jest": "^29.1.2",
    "typescript": "^5.3.3"
  }
}
